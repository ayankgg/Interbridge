# ===== Server =====
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:3000

# ===== Database =====
MONGODB_URI=mongodb://127.0.0.1:27017/internbridge

# ===== JWT =====
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_RESET_SECRET=replace_with_long_random_reset_secret
JWT_RESET_EXPIRES_IN=15m

# ===== Bcrypt =====
BCRYPT_SALT_ROUNDS=12

# ===== Cookies =====
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ===== Cloudinary =====
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=internbridge

# ===== Gemini AI =====
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# ===== Email (SMTP) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="InternBridge <no-reply@internbridge.com>"

# ===== Twilio WhatsApp =====
# Leave blank to run in no-op mode (messages are logged, not sent).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ===== Rate Limiting =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20

# ===== Logging =====
LOG_LEVEL=info

# ===== Scheduled Jobs =====
# Run cron jobs on this instance. In multi-instance deployments set to 'true'
# on exactly ONE instance (or a dedicated worker) to avoid duplicate work.
ENABLE_SCHEDULED_JOBS=true
